# --- CultureForge: large generated databases and caches ---
data/cultureforge.db
data/cultureforge.db-journal
/cultureforge.db
/cultureforge.sqlite

# Cached external-API records (rebuildable via download_*.py)
data/bacdive/strains/
data/mediadive/all_media.json
data/mediadive/index.json
data/mediadive/media/
data/mediadive/medium_strains/
data/mediadive/medium_*.json
data/mediadive/medium_recipes/

# Copyrighted PDFs (do not redistribute)
data/thermo/*.pdf

# TEMPURA data (CC BY-NC 3.0 — non-commercial license incompatible
# with MIT redistribution; users download from togodb.org/db/tempura)
data/tempura/tempura.csv
data/tempura/new_16s_accessions.json

# Derived 16S indices (rebuildable from BacDive + TEMPURA via fetch_16s_*.py)
data/16s_accessions.json
data/16s_acc_to_bid.json
data/16s_unique.fasta

# CAZyme generated inputs (regenerable from gapseq/proteome data)
data/cazyme/*/uniInput.faa
data/cazyme/*/output/

# Generated validation profile dumps
data/validation/phase1_capability_profiles.txt
data/validation/phase1_5_capability_profiles.txt
data/validation/phase1_*_capability_profiles.txt
data/validation/phase2c_recipes/

# Vendored GenomeSPOT — exclude bulky non-runtime content
# (notebooks ~13 MB, test data ~5.5 MB, build artifacts, holdout fixtures)
vendor/GenomeSPOT/.git/
vendor/GenomeSPOT/notebooks/
vendor/GenomeSPOT/tests/test_data/
vendor/GenomeSPOT/data/holdouts/
vendor/GenomeSPOT/build/
vendor/GenomeSPOT/.vscode/

# Coverage audit / dbCAN db / hydrogenase prebuilt DBs
data/coverage_audit/*.json
data/dbcan_db/
data/hydrogenase/hydrogenase_ref.fasta

# Downloaded genome assemblies (rebuildable via NCBI download)
data/genomes/
data/sentinel/*/proteome.faa
data/sentinel/*/genome.fna
data/sentinel/*/*.faa
data/sentinel/*/*.fna

# Phase 4.1 user-loaded genomes — keep only the documentation outputs
# (BLIND_TEST_RESULT.md, inspect_full_report.txt). Pipeline artifacts
# regenerable from the source genome.
data/user_genomes/*/genome.fna
data/user_genomes/*/proteome.faa
data/user_genomes/*/genes.gff
data/user_genomes/*/gapseq/
data/user_genomes/*/genomespot/
data/user_genomes/*/checkm2/
data/user_genomes/*/mebipred/
data/user_genomes/*/inspect_full_report.json

# gapseq output (regenerable; large; per-genome)
data/gapseq/*/
*.RDS

# GenomeSPOT output
data/genomespot/

# CheckM2 / MeBiPred output
data/checkm2/
data/mebipred/

# 16S reference database (built from BacDive/TEMPURA via fetch_16s_*.py)
data/16s_reference.fasta
data/16s_unique.fasta
data/blastdb/

# BLAST databases for diagnostic markers (rebuilt from data/diagnostic_markers/*_refs.fasta)
data/diagnostic_markers/blastdb_*.phr
data/diagnostic_markers/blastdb_*.pin
data/diagnostic_markers/blastdb_*.psq
data/diagnostic_markers/blastdb_*.pdb
data/diagnostic_markers/blastdb_*.pot
data/diagnostic_markers/blastdb_*.ptf
data/diagnostic_markers/blastdb_*.pto

# BLAST databases for sentinel proteomes
data/sentinel/*/genome_db.*

# Hydrogenase reference DB (rebuildable)
data/hydrogenase/hydrogenase_ref.*

# Logs
